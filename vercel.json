{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/public/latest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=60"
        },
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        }
      ]
    }
  ]
}
