{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shinobionline.vercel.app/public/latest.schema.json",
  "title": "Shinobi Online latest release manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "game",
    "channel",
    "version",
    "status",
    "publishedAt",
    "installer",
    "runtimePackage",
    "launcher",
    "compatibility",
    "releaseNotesUrl",
    "message"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "game": {
      "const": "Shinobi Online"
    },
    "channel": {
      "enum": ["production", "staging"]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
    },
    "status": {
      "enum": ["pending-release", "available", "withdrawn"]
    },
    "publishedAt": {
      "type": ["string", "null"]
    },
    "installer": {
      "anyOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "type": "null"
        }
      ]
    },
    "runtimePackage": {
      "anyOf": [
        {
          "$ref": "#/$defs/runtimePackage"
        },
        {
          "type": "null"
        }
      ]
    },
    "launcher": {
      "type": "object",
      "required": ["currentVersion", "minimumVersion"],
      "properties": {
        "currentVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
        },
        "minimumVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
        }
      },
      "additionalProperties": false
    },
    "clientBuild": {
      "$ref": "#/$defs/clientBuild"
    },
    "android": {
      "$ref": "#/$defs/androidRelease"
    },
    "compatibility": {
      "type": "object",
      "required": ["os", "architecture", "graphics", "prerequisiteMode"],
      "properties": {
        "os": {
          "const": "Windows 10 or newer"
        },
        "architecture": {
          "const": "x64"
        },
        "graphics": {
          "const": "OpenGL-capable GPU driver"
        },
        "prerequisiteMode": {
          "const": "detect-and-guide"
        }
      },
      "additionalProperties": false
    },
    "releaseNotesUrl": {
      "type": "string"
    },
    "message": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "available"
          }
        }
      },
      "then": {
        "required": ["publishedAt", "installer", "runtimePackage", "clientBuild"],
        "properties": {
          "publishedAt": {
            "type": "string"
          },
          "installer": {
            "$ref": "#/$defs/artifact"
          },
          "runtimePackage": {
            "$ref": "#/$defs/runtimePackage"
          },
          "clientBuild": {
            "$ref": "#/$defs/clientBuild"
          }
        }
      }
    }
  ],
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["fileName", "url", "sha256", "sizeBytes"],
      "properties": {
        "fileName": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "pattern": "^https://github\\.com/frizas/shinobi-online/releases/download/"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "runtimePackage": {
      "type": "object",
      "required": ["fileName", "url", "sha256", "sizeBytes", "runtimeManifestSha256"],
      "properties": {
        "fileName": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "pattern": "^https://github\\.com/frizas/shinobi-online/releases/download/"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        },
        "runtimeManifestSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "clientBuild": {
      "type": "object",
      "required": ["current", "accepted", "minimumAcceptedVersion", "updateMode"],
      "properties": {
        "current": {
          "$ref": "#/$defs/clientBuildEntry"
        },
        "accepted": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/clientBuildEntry"
          }
        },
        "minimumAcceptedVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
        },
        "updateMode": {
          "const": "launcher"
        }
      },
      "additionalProperties": false
    },
    "androidRelease": {
      "type": "object",
      "required": [
        "versionName",
        "versionCode",
        "minimumVersionCode",
        "packageName",
        "updateMode",
        "downloadUrl",
        "apk",
        "runtimePackage"
      ],
      "properties": {
        "versionName": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
        },
        "versionCode": {
          "type": "integer",
          "minimum": 1
        },
        "minimumVersionCode": {
          "type": "integer",
          "minimum": 1
        },
        "packageName": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*(\\.[A-Za-z][A-Za-z0-9_]*)+$"
        },
        "updateMode": {
          "const": "website"
        },
        "downloadUrl": {
          "type": "string"
        },
        "apk": {
          "$ref": "#/$defs/artifact"
        },
        "runtimePackage": {
          "$ref": "#/$defs/runtimePackage"
        },
        "acceptedRuntimePackages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/clientBuildEntry"
          }
        }
      },
      "additionalProperties": false
    },
    "clientBuildEntry": {
      "type": "object",
      "required": ["version", "token", "tokenKind", "publishedAt"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
        },
        "token": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "tokenKind": {
          "const": "runtimeManifestSha256"
        },
        "publishedAt": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
